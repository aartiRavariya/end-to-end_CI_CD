# Environment Variables Template
# Copy this to .env and fill in actual values

# ============================================
# Docker Hub Credentials
# ============================================
DOCKERHUB_USERNAME=your_docker_username
DOCKERHUB_TOKEN=your_docker_hub_token_or_password
DOCKERHUB_REGISTRY=docker.io

# ============================================
# GitHub Configuration
# ============================================
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_USERNAME=your_github_username
GITHUB_REPO=end-to-end_CI_CD

# ============================================
# Kubernetes Configuration
# ============================================
KUBECONFIG=~/.kube/config
KUBERNETES_NAMESPACE=ml-project

# ============================================
# Argo CD Configuration
# ============================================
ARGOCD_SERVER=argocd.example.com:443
ARGOCD_USERNAME=admin
ARGOCD_PASSWORD=your_argocd_password
ARGOCD_INSECURE=false

# ============================================
# Database Configuration
# ============================================
DB_HOST=postgres-service.ml-project.svc.cluster.local
DB_PORT=5432
DB_NAME=ml_db
DB_USER=ml_user
DB_PASSWORD=your_secure_db_password

POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_postgres_password
POSTGRES_DB=ml_db

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=redis-service.ml-project.svc.cluster.local
REDIS_PORT=6379
USE_REDIS=true

# ============================================
# FastAPI Configuration
# ============================================
FASTAPI_URL=http://fastapi-service.ml-project.svc.cluster.local:8000
FASTAPI_WORKERS=4
LOG_LEVEL=INFO

# ============================================
# Streamlit Configuration
# ============================================
STREAMLIT_URL=http://localhost:8501
STREAMLIT_SERVER_HEADLESS=true

# ============================================
# Prometheus Configuration
# ============================================
PROMETHEUS_RETENTION=30d
PROMETHEUS_SCRAPE_INTERVAL=15s

# ============================================
# Grafana Configuration
# ============================================
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=your_secure_grafana_password
GF_INSTALL_PLUGINS=grafana-piechart-panel

# ============================================
# Monitoring & Logging
# ============================================
LOG_FORMAT=json
LOG_LEVEL=INFO

# ============================================
# Feature Flags
# ============================================
ENABLE_MONITORING=true
ENABLE_CACHING=true
ENABLE_DATABASE_LOGGING=true
